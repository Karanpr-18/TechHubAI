# ===========================
# TechHubAI Configuration
# ===========================

# Primary LLM API Key (for debate agents & judge)
# Supports: OpenAI, Anthropic, Groq
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# Which provider to use for the main debate agents
# Options: openai, anthropic, groq
PRIMARY_LLM_PROVIDER=groq

# Which model to use for the main debate agents
PRIMARY_LLM_MODEL=llama-3.3-70b-versatile

# Which provider/model to use for token optimization (pre-summarization)
SUMMARIZER_LLM_PROVIDER=groq
SUMMARIZER_LLM_MODEL=llama-3.3-70b-versatile

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Token Rate Limiting (Tokens Per Minute limit)
MAX_TPM=6000
